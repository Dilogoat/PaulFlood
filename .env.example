DATABASE_URL="postgresql://paulflood:paulflood@localhost:5432/paulflood"

# Auth — generate hash: npm run hash-password -- "your-password"
# IMPORTANT: bcrypt hashes contain $ — escape each as \$ in .env (Next.js expands $ otherwise)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="\$2b\$12\$EXAMPLE..."
SESSION_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"

# Storage (issue #2 / #20)
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage/uploads"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
